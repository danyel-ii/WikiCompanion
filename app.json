{
  "expo": {
    "name": "Cyber Tool Atlas",
    "slug": "cyber-tool-atlas",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon-pyr.png",
    "scheme": "cybertools",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#091018"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.danyel.wikicompanion"
    },
    "android": {
      "package": "io.danyel.wikicompanion",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-pyr.png",
        "backgroundColor": "#091018"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
