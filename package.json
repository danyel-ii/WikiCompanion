{
  "name": "cyber-tool-atlas",
  "main": "expo-router/entry",
  "version": "1.1.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "vitest run",
    "build:web": "expo export --platform web",
    "build:android:apk": "bash scripts/build-android-apk.sh debug",
    "build:android:release": "bash scripts/build-android-apk.sh release",
    "content:sync": "tsx scripts/fetch-upstream.ts && tsx scripts/parse-skills.ts",
    "content:generate": "tsx scripts/build-tools.ts && tsx scripts/generate-articles.ts && tsx scripts/build-manifest.ts",
    "content:all": "npm run content:sync && npm run content:generate",
    "knowledge:extract": "tsx scripts/extract-tool-knowledge.ts",
    "knowledge:synthesize": "tsx scripts/synthesize-tool-knowledge.ts",
    "knowledge:wiki": "tsx scripts/generate-tool-wiki.ts",
    "knowledge:all": "npm run knowledge:extract && npm run knowledge:synthesize && npm run knowledge:wiki",
    "knowledge:wiki:openai": "tsx scripts/generate-tool-wiki-openai.ts",
    "knowledge:wiki:openai:test": "tsx scripts/generate-tool-wiki-openai.ts --slugs volatility,wireshark --limit 2 --force",
    "wiki:site": "tsx scripts/build-wiki-site.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.3.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-file-system": "^55.0.14",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "react-test-renderer": "19.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.2"
  },
  "private": true
}
